{
  "name": "kesb-survey-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js,json --delay 1000ms --exec \"node src/index.js\"",
    "start": "node dist/src/index.js",
    "build": "mkdir -p dist && cp -r src dist && cp -r data dist/data"
  },
  "dependencies": {
