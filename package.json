{
  "name": "kesb-survey",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install --workspaces --include-workspace-root",
    "dev": "npm-run-all --parallel dev:*",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev -- --host 0.0.0.0",
    "build": "npm-run-all build:*",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
